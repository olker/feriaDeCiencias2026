<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteRule ^\.env$ - [F,L,NC]
    RewriteRule ^artisan$ - [F,L,NC]
    RewriteRule ^composer\.(json|lock)$ - [F,L,NC]
    RewriteRule ^package(-lock)?\.json$ - [F,L,NC]

    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

<FilesMatch "^\.">
    Require all denied
</FilesMatch>